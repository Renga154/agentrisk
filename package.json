{
  "name": "agentrisk",
  "version": "0.1.0",
  "description": "Static risk scanner for AI-agent and MCP workspace configuration.",
  "type": "module",
  "homepage": "https://github.com/satourenware/agentrisk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/satourenware/agentrisk.git"
  },
  "bugs": {
    "url": "https://github.com/satourenware/agentrisk/issues"
  },
  "bin": {
    "agentrisk": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --target node20 --dts --clean --sourcemap",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build",
    "prepublishOnly": "npm run check && npm audit --audit-level=moderate"
  },
  "keywords": [
    "ai-agent",
    "mcp",
    "security",
    "sarif",
    "scanner",
    "codex",
    "claude",
    "cursor",
    "copilot"
  ],
  "author": "satourenware",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.2",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.15",
    "@typescript-eslint/eslint-plugin": "^8.0.1",
    "@typescript-eslint/parser": "^8.0.1",
    "eslint": "^9.8.0",
    "tsup": "^8.2.4",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4",
    "vitest": "^4.1.9"
  }
}
