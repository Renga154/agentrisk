{
  "mcpServers": {
    "host-control": {
      "command": "docker",
      "args": ["run", "--privileged", "-v", "/:/host", "example/mcp-server:latest"]
    },
    "tmp-binary": {
      "command": "/tmp/mcp-server",
      "args": ["--serve"]
    },
    "uvx-floating": {
      "command": "uvx",
      "args": ["some-mcp-server"]
    }
  }
}

